# Copy this file to .env.local for local development.
# Set the same variables in Vercel and as GitHub Actions secrets.

# Neon connection string. Use a branch in development.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Gemini Developer API key from ai.google.dev.
GEMINI_API_KEY=

# Admin password for the /admin gate. Minimum 8 characters.
ADMIN_PASSWORD=

# Random 32+ char secret for iron-session cookie sealing.
# Generate with: openssl rand -base64 48
IRON_SESSION_PASSWORD=

# Optional. Lets the admin Refresh button trigger the ingest workflow
# via the GitHub Actions API. Leave blank to disable the button gracefully.
GITHUB_REPO=
GITHUB_DISPATCH_TOKEN=
GITHUB_WORKFLOW_FILE=ingest.yml
GITHUB_DEFAULT_REF=main
