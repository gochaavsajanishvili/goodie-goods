{
  "name": "goodie-goods",
  "version": "0.1.0",
  "private": true,
  "description": "A calm corner of the internet that surfaces only the good news from ambebi.ge.",
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "build": "bun run --filter web build",
    "start": "bun run --filter web start",
    "ingest": "bun run --filter ingest start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun run --filter web test:e2e",
    "test:coverage": "bun run --filter '*' test:coverage",
    "dupes": "jscpd .",
    "deadcode": "knip",
    "check:i18n": "bun run scripts/check-georgian.ts",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test && bun run dupes && bun run deadcode && bun run check:i18n && bun run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/js": "^10.0.1",
    "@types/node": "latest",
    "dotenv-cli": "^11.0.0",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-secrets": "latest",
    "eslint-plugin-promise": "latest",
    "eslint-plugin-security": "latest",
    "eslint-plugin-sonarjs": "latest",
    "eslint-plugin-unicorn": "latest",
    "globals": "latest",
    "husky": "latest",
    "jscpd": "latest",
    "knip": "latest",
    "lint-staged": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
