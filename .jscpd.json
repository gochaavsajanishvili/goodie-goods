{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/core/schema.json",
  "threshold": 0,
  "minLines": 5,
  "minTokens": 30,
  "reporters": ["console"],
  "exitCode": 1,
  "ignoreCase": false,
  "absolute": false,
  "noSymlinks": true,
  "blame": false,
  "format": ["typescript", "tsx", "javascript", "jsx", "css", "scss", "sql", "bash"],
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/test/**",
    "**/tests/**",
    "**/fixtures/**",
    "**/__fixtures__/**",
    "**/__mocks__/**",
    "**/*.d.ts",
    "**/bun.lock",
    "**/package-lock.json",
    "**/yarn.lock",
    "**/pnpm-lock.yaml"
  ]
}
